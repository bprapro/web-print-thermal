<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cetak ke Thermal 58mm via Web</title>
    <style>
        * { box-sizing: border-box; font-family: 'Courier New', Courier, monospace; }
        body { background-color: #f4f4f9; padding: 20px; display: flex; justify-content: center; }
        .container { background: #fff; width: 100%; max-width: 400px; padding: 20px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); }
        h2 { text-align: center; border-bottom: 2px dashed #333; padding-bottom: 10px; margin-bottom: 15px; }
        .form-group { margin-bottom: 15px; }
        label { font-weight: bold; display: block; margin-bottom: 5px; font-size: 14px; }
        input, select, textarea { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
        .btn-group { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
        button { padding: 12px; font-weight: bold; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
        .btn-connect { background: #2980b9; color: white; }
        .btn-print { background: #27ae60; color: white; }
        .status { margin-top: 15px; padding: 10px; background: #eee; text-align: center; font-size: 12px; border-radius: 4px; font-weight: bold; }
        /* Preview ala Struk 58mm */
        .receipt-preview { background: #fffde7; border: 1px dashed #999; padding: 15px; font-size: 12px; margin-top: 15px; white-space: pre-wrap; word-break: break-all; }
    </style>
</head>
<body>

<div class="container">
    <h2>🖨️ Thermal 58mm</h2>

    <div class="form-group">
        <label for="header">Nama Toko / Judul</label>
        <input type="text" id="header" value="PRINT EXPRESS 58MM">
    </div>

    <div class="form-group">
        <label for="jenis">Jenis Layanan</label>
        <select id="jenis">
            <option value="CETAK DOKUMEN">Cetak Dokumen</option>
            <option value="CETAK FOTO / STRUK">Cetak Foto / Struk</option>
            <option value="NOTA LAINNYA">Nota / Catatan</option>
        </select>
    </div>

    <div class="form-group">
        <label for="pesan">Isi Teks / Catatan</label>
        <textarea id="pesan" rows="4" placeholder="Tulis teks atau informasi yang ingin dicetak...">Terima kasih telah menggunakan jasa print online kami. Harap simpan resi ini.</textarea>
    </div>

    <div class="btn-group">
        <button class="btn-connect" onclick="connectPrinter()">🔌 Sambungkan Printer (Bluetooth)</button>
        <button class="btn-print" onclick="printThermal()">🖨️ Cetak Sekarang</button>
    </div>

    <div id="status" class="status">Status: Belum Terhubung</div>

    <label style="margin-top: 20px;">Pratinjau Kertas 58mm:</label>
    <div id="preview" class="receipt-preview"></div>
</div>

<script>
    let bluetoothDevice;
    let gattCharacteristic;

    // Fungsi Mengisi Pratinjau Teks
    function updatePreview() {
        const header = document.getElementById('header').value;
        const jenis = document.getElementById('jenis').value;
        const pesan = document.getElementById('pesan').value;
        const date = new Date().toLocaleString('id-ID');

        const previewText = `${header.center(32)}\n` +
                            `--------------------------------\n` +
                            `Waktu : ${date}\n` +
                            `Layanan: ${jenis}\n` +
                            `--------------------------------\n` +
                            `${pesan}\n\n` +
                            `--------------------------------\n` +
                            `* SIMPAN RESI INI *\n`.center(32);

        document.getElementById('preview').innerText = previewText;
    }

    // Helper untuk meratakan teks ke tengah (32 Karakter untuk 58mm)
    String.prototype.center = function(width) {
        let padding = Math.floor((width - this.length) / 2);
        return padding > 0 ? " ".repeat(padding) + this + " ".repeat(padding) : this;
    };

    document.getElementById('header').addEventListener('input', updatePreview);
    document.getElementById('jenis').addEventListener('change', updatePreview);
    document.getElementById('pesan').addEventListener('input', updatePreview);
    updatePreview();

    // 1. Hubungkan Browser ke Printer Thermal via Bluetooth
    async function connectPrinter() {
        const statusEl = document.getElementById('status');
        try {
            statusEl.innerText = "Mencari printer Bluetooth...";
            
            // Mencari perangkat Bluetooth yang mendukung Serial Port Service (SPP)
            bluetoothDevice = await navigator.bluetooth.requestDevice({
                acceptAllDevices: true,
                optionalServices: ['00001101-0000-1000-8000-00805f9b34fb'] // standard SPP UUID
            });

            statusEl.innerText = `Menghubungkan ke ${bluetoothDevice.name}...`;
            const server = await bluetoothDevice.gatt.connect();
            const service = await server.getPrimaryService('00001101-0000-1000-8000-00805f9b34fb');
            
            const characteristics = await service.getCharacteristics();
            gattCharacteristic = characteristics[0]; // Ambil kanal pengiriman data

            statusEl.innerText = `Terhubung ke: ${bluetoothDevice.name} ✅`;
            statusEl.style.background = "#d4edda";
            statusEl.style.color = "#155724";
        } catch (error) {
            console.error(error);
            statusEl.innerText = "Gagal terhubung: " + error.message;
            statusEl.style.background = "#f8d7da";
            statusEl.style.color = "#721c24";
        }
    }

    // 2. Kirim Perintah Cetak (ESC/POS)
    async function printThermal() {
        const statusEl = document.getElementById('status');
        if (!gattCharacteristic) {
            alert("Harap sambungkan printer Bluetooth terlebih dahulu!");
            return;
        }

        try {
            const encoder = new TextEncoder();
            
            // Perintah ESC/POS standar
            const ESC = '\x1B';
            const GS = '\x1D';
            const INIT = ESC + '@';               // Reset printer
            const CENTER = ESC + 'a' + '\x01';    // Rata tengah
            const LEFT = ESC + 'a' + '\x00';      // Rata kiri
            const BOLD_ON = ESC + 'E' + '\x01';   // Teks tebal ON
            const BOLD_OFF = ESC + 'E' + '\x00';  // Teks tebal OFF
            const FEED = '\n\n\n';               // Feed kertas akhir

            const header = document.getElementById('header').value;
            const jenis = document.getElementById('jenis').value;
            const pesan = document.getElementById('pesan').value;
            const date = new Date().toLocaleString('id-ID');

            // Susun instruksi cetak
            let printData = INIT;
            printData += CENTER + BOLD_ON + header + '\n' + BOLD_OFF;
            printData += "--------------------------------\n";
            printData += LEFT;
            printData += `Waktu  : ${date}\n`;
            printData += `Layanan: ${jenis}\n`;
            printData += "--------------------------------\n";
            printData += `${pesan}\n\n`;
            printData += CENTER;
            printData += "--------------------------------\n";
            printData += "* TERIMA KASIH *\n";
            printData += FEED;

            // Kirim data buffer ke printer
            const dataBuffer = encoder.encode(printData);
            await gattCharacteristic.writeValue(dataBuffer);

            statusEl.innerText = "Berhasil mencetak! 🖨️";
        } catch (error) {
            console.error(error);
            alert("Gagal mencetak: " + error.message);
        }
    }
</script>
</body>
</html>
